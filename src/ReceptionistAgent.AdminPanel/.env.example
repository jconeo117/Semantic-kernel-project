# ─── ReceptionistAI Admin Panel ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to the repo.

# Backend API URL (default for local development)
VITE_API_BASE_URL=http://localhost:5083

# API Key — must match one of the keys in Security:ApiKeys on the backend.
# Set on backend with: dotnet user-secrets set "Security:ApiKeys:0" "YOUR_KEY"
VITE_API_KEY=YOUR_API_KEY_HERE
